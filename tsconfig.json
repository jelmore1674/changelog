{
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": [
      "esnext"
    ],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/parser/*": ["./src/parser/*"],
      "@/write/*": ["./src/write/*"],
      "@/regex": ["./src/regex/index.ts"],
      "@/types": ["./src/types/index.ts"]
    }
  }
}
